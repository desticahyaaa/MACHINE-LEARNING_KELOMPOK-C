# Deteksi Outlier dengan IQR untuk semua kolom numerik
all_numerical_cols = df.select_dtypes(include=np.number).columns

print("Deteksi Outlier menggunakan IQR untuk Semua Kolom Numerik:\n")
for col in all_numerical_cols:
    Q1 = df[col].quantile(0.25)
    Q3 = df[col].quantile(0.75)
    IQR = Q3 - Q1
    lower_bound = Q1 - 1.5 * IQR
    upper_bound = Q3 + 1.5 * IQR
    outliers = df[(df[col] < lower_bound) | (df[col] > upper_bound)]

    print(f"Variabel: {col}")
    print(f"  Jumlah Outlier: {len(outliers)}")
    if len(outliers) > 0:
        print(f"  Nilai Outlier: ")
        display(outliers[[col]])
    print("---------------------------------")
